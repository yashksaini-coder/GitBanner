# GitHub Personal Access Token used by the local CLI dev runner.
# Required scopes:
#   - read:user            (always required)
#   - repo                 (only if --include-private is passed)
#
# Classic tokens:      https://github.com/settings/tokens
# Fine-grained tokens: https://github.com/settings/personal-access-tokens
GH_PAT=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Alternative name accepted by the CLI if GH_PAT is unset.
# GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Default GitHub login to render. Override on the CLI with --user.
# GITBANNER_USER=yashksaini-coder
